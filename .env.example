APP_NAME=haojixing
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:9001
SESSION_DRIVER=file
CACHE_STORE=file

APP_HOST=localhost
APP_PORT=9001
APP_FPM_PORT=9000
COMPOSE_PROJECT_NAME=haojixing

APP_UID=1000
APP_GID=1000

# 调试默认关闭，调试模式再开启
ENABLE_XDEBUG=0
XDEBUG_MODE=off
XDEBUG_CLIENT_HOST=host.containers.internal
XDEBUG_CLIENT_PORT=9003

DB_CONNECTION=pgsql
DB_HOST=host.containers.internal
DB_PORT=5432
DB_DATABASE=haojixing
DB_USERNAME=haojixing
DB_PASSWORD=change_me
DB_FORWARD_PORT=5432
PODMAN_HOST_GATEWAY_IP=10.89.0.1

# Postgres 容器自身初始化参数（与应用 DB_* 解耦）
PG_DB_DATABASE=haojixing
PG_DB_USERNAME=haojixing
PG_DB_PASSWORD=change_me

REDIS_HOST=host.containers.internal
REDIS_PORT=6379
REDIS_PASSWORD=null
REDIS_FORWARD_PORT=6379

# 后台管理页面 HTTP Basic 账号
ADMIN_UI_USER=admin
ADMIN_UI_PASSWORD=change_me

# Telegram 机器人配置
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_ID=
# 当容器 DNS 不稳定时可配置（示例：149.154.167.220）
TELEGRAM_API_RESOLVE_IP=149.154.166.110
TELEGRAM_WEBHOOK_SECRET=
